#!/usr/bin/env sh
# Local Linux/macOS environment script for CMake/vcpkg with the Clang toolchain.
# Copy this file to .env.sh, adjust DEV_TOOLS_ROOT or VCPKG_ROOT if needed,
# then source it before configuring: . ./scripts/env.sh

: "${DEV_TOOLS_ROOT:=$HOME/.local}"
: "${VCPKG_ROOT:=$DEV_TOOLS_ROOT/vcpkg}"

QRP_UNAME_S="$(uname -s 2>/dev/null || echo unknown)"
QRP_UNAME_M="$(uname -m 2>/dev/null || echo unknown)"

if [ -z "${VCPKG_TARGET_TRIPLET:-}" ]; then
    case "$QRP_UNAME_S:$QRP_UNAME_M" in
        Darwin:arm64|Darwin:aarch64)
            VCPKG_TARGET_TRIPLET="arm64-osx"
            ;;
        Darwin:*)
            VCPKG_TARGET_TRIPLET="x64-osx"
            ;;
        Linux:arm64|Linux:aarch64)
            VCPKG_TARGET_TRIPLET="arm64-linux"
            ;;
        Linux:*)
            VCPKG_TARGET_TRIPLET="x64-linux"
            ;;
    esac
fi

: "${CC:=clang}"
: "${CXX:=clang++}"
: "${QRP_ENV_FILE:=$PWD/.env.sh}"
QRP_ENV_PROFILE="clang"

qrp_prepend_path() {
    if [ -d "$1" ]; then
        case ":${PATH:-}:" in
            *":$1:"*) ;;
            *) PATH="$1${PATH:+:$PATH}" ;;
        esac
    fi
}

qrp_prepend_path "/usr/local/bin"
qrp_prepend_path "/opt/homebrew/bin"
qrp_prepend_path "$VCPKG_ROOT"
qrp_prepend_path "$DEV_TOOLS_ROOT/ninja"
qrp_prepend_path "$DEV_TOOLS_ROOT/bin"

export CC
export CXX
export DEV_TOOLS_ROOT
export PATH
export QRP_ENV_FILE
export QRP_ENV_PROFILE
export VCPKG_ROOT
export VCPKG_TARGET_TRIPLET

unset QRP_UNAME_M
unset QRP_UNAME_S
unset -f qrp_prepend_path 2>/dev/null || true
